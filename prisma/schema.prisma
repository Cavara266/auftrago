generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  OPEN
  CONTACTED
  APPOINTMENT_SET
  OFFER_SENT
  WON
  LOST
  NO_OFFER
}

enum OfferStatus {
  SENT
  ACCEPTED
  DECLINED
}

enum ProviderStatus {
  PENDING
  APPROVED
  BLOCKED
}

model Provider {
  id          String         @id @default(uuid())
  email       String         @unique
  password    String
  companyName String
  contactName String
  phone       String?
  credits     Int            @default(0)
  status      ProviderStatus @default(PENDING)

  slug String? @unique

  region   String?
  category String?

  logoUrl     String?
  website     String?
  description String?
  address     String?
  postalCode  String?
  city        String?

  serviceCategories  String[] @default([])
  serviceRegions     String[] @default([])
  serviceCities      String[] @default([])
  servicePostalCodes String[] @default([])

  receiveLeadEmails    Boolean @default(true)
  receiveAllLeadEmails Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases       LeadPurchase[]
  creditPurchases CreditPurchase[]
  activities      ProviderActivity[]

  @@index([status])
  @@index([slug])
  @@index([createdAt])
  @@index([updatedAt])
}

model Lead {
  id          String @id @default(uuid())
  title       String
  description String

  name  String
  email String
  phone String

  region   String
  category String
  price    Int

  postalCode String?
  city       String?

  maxPurchases Int       @default(4)
  expiresAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases LeadPurchase[]

  @@index([createdAt])
  @@index([expiresAt])
  @@index([category])
  @@index([region])
  @@index([postalCode])
  @@index([city])
  @@index([category, region])
  @@index([expiresAt, createdAt])
}

model LeadPurchase {
  id         String     @id @default(uuid())
  providerId String
  leadId     String
  price      Int
  status     LeadStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  notes      LeadNote[]
  messages   LeadMessage[]
  activities LeadActivity[]
  offers     LeadOffer[]

  @@unique([providerId, leadId])
  @@index([providerId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([providerId, createdAt])
}

model LeadNote {
  id             String @id @default(uuid())
  leadPurchaseId String
  content        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadPurchase LeadPurchase @relation(fields: [leadPurchaseId], references: [id], onDelete: Cascade)

  @@index([leadPurchaseId])
  @@index([createdAt])
}

model LeadMessage {
  id             String @id @default(uuid())
  leadPurchaseId String
  sender         String
  message        String

  createdAt DateTime @default(now())

  leadPurchase LeadPurchase @relation(fields: [leadPurchaseId], references: [id], onDelete: Cascade)

  @@index([leadPurchaseId])
  @@index([createdAt])
}

model LeadActivity {
  id             String @id @default(uuid())
  leadPurchaseId String
  type           String
  description    String

  createdAt DateTime @default(now())

  leadPurchase LeadPurchase @relation(fields: [leadPurchaseId], references: [id], onDelete: Cascade)

  @@index([leadPurchaseId])
  @@index([type])
  @@index([createdAt])
  @@index([leadPurchaseId, createdAt])
}

model LeadOffer {
  id             String      @id @default(uuid())
  leadPurchaseId String
  title          String
  description    String?
  amount         Float
  status         OfferStatus @default(SENT)
  pdfUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadPurchase LeadPurchase @relation(fields: [leadPurchaseId], references: [id], onDelete: Cascade)

  @@index([leadPurchaseId])
  @@index([status])
  @@index([createdAt])
}

model CreditPurchase {
  id              String  @id @default(uuid())
  providerId      String
  stripeSessionId String  @unique
  packageId       String?
  credits         Int
  amount          Int
  currency        String  @default("chf")
  status          String  @default("paid")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@index([providerId, createdAt])
}

model ProviderActivity {
  id          String  @id @default(uuid())
  providerId  String
  event       String
  description String?
  page        String?
  leadId      String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([providerId, createdAt])
  @@index([event, createdAt])
  @@index([leadId])
  @@index([createdAt])
}

model SmartPricingSettings {
  id String @id @default("default")

  enabled Boolean @default(true)

  firstAfterDays       Int @default(3)
  firstDiscountPercent Int @default(15)

  secondAfterDays       Int @default(5)
  secondDiscountPercent Int @default(30)

  thirdAfterDays       Int @default(6)
  thirdDiscountPercent Int @default(50)

  minimumPrice       Int     @default(10)
  resetAfterPurchase Boolean @default(true)
  label              String  @default("Smart Deal")
  showCountdown      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id String @id @default(uuid())

  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@index([email, expiresAt])
}
