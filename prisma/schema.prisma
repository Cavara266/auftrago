generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  companyName  String
  contactName  String
  phone        String?
  region       String?
  category     String?
  credits      Int            @default(0)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  purchases    LeadPurchase[]
}

model Lead {
  id           String         @id @default(uuid())
  title        String
  description  String

  name         String
  email        String
  phone        String

  region       String
  category     String
  price        Int

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  purchases    LeadPurchase[]
}

model LeadPurchase {
  id           String    @id @default(uuid())
  providerId   String
  leadId       String
  price        Int

  createdAt    DateTime  @default(now())

  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([providerId, leadId])
}